{
    "kind": "collectionType",
    "collectionName": "news_list",
    "info": {
        "singularName": "news",
        "pluralName": "news-list",
        "displayName": "News",
        "description": "News articles and announcements"
    },
    "options": {
        "draftAndPublish": true
    },
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "summary": {
            "type": "text",
            "required": true
        },
        "content": {
            "type": "richtext"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "category": {
            "type": "string"
        }
    }
}
