{
    "kind": "collectionType",
    "collectionName": "countries",
    "info": {
        "singularName": "country",
        "pluralName": "countries",
        "displayName": "Country",
        "description": "Countries where students can study"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {
        "i18n": {
            "localized": true
        }
    },
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "unique": true,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "cities": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::city.city",
            "mappedBy": "country"
        },
        "description": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "featured": {
            "type": "boolean",
            "default": false
        },
        "images": {
            "type": "media",
            "multiple": true,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        }
    }
}