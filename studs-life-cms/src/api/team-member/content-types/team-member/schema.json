{
    "kind": "collectionType",
    "collectionName": "team_members",
    "info": {
        "singularName": "team-member",
        "pluralName": "team-members",
        "displayName": "Team Member",
        "description": "Team members and staff profiles"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {
        "i18n": {
            "localized": true
        }
    },
    "attributes": {
        "slug": {
            "type": "uid",
            "targetField": "fullName",
            "required": true
        },
        "fullName": {
            "type": "string",
            "required": true,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "role": {
            "type": "string",
            "required": true,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "photo": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "city": {
            "type": "string",
            "required": true,
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "officeAddress": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "birthDate": {
            "type": "date"
        },
        "startDate": {
            "type": "date"
        },
        "languages": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "phone": {
            "type": "string"
        },
        "email": {
            "type": "string"
        },
        "responsibilities": {
            "type": "richtext",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "order": {
            "type": "integer",
            "default": 0
        },
        "office": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::office.office",
            "inversedBy": "teamMembers"
        }
    }
}