# ==============================================================================
# STUDS-LIFE FRONTEND - ENVIRONMENT VARIABLES CONFIGURATION (.env.local)
# ==============================================================================

# 1) Google Sheets Entegrasyonu
# Apps Script üzerinden oluşturduğunuz Web Application URL'sini buraya yapıştırın.
# Tüm form verilerinin tabloya akması için zorunludur.
NEXT_PUBLIC_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/YOUR_MACRO_ID/exec

# 2) Strapi CMS Bağlantısı
# Eğer Strapi CMS'i farklı bir sunucuda veya portta çalıştırıyorsanız burayı güncelleyin.
# Docker ile kuruyorsanız ve aynı sunucudaysanız kendi IP adresinizi ve 1337 portunu girin.
# Örnek: http://192.168.1.100:1337 veya https://cms.studs-life.com
NEXT_PUBLIC_STRAPI_URL=http://72.62.37.145:1337

# 3) CRM (manager-sl.ru) Entegrasyonu
# manager-sl.ru API sisteminizden aldığınız Private API Key değerini buraya girin.
# Bu değer sunucu (backend/API Route) tarafında kullanılacak olup, tarayıcıda asla görünmez.
CRM_API_KEY=your_secure_api_key_goes_here
